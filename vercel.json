{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/article/:id*", "destination": "/article.html" }
  ],
  "headers": [
    {
      "source": "/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
